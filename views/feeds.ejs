<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snapgram</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/fontawesome-web/css/all.css">
    <link rel="stylesheet" href="/css/fontawesome-web/css/all.min.css">
    <link rel="stylesheet" href="/css/custom/pages.css">
    <link rel="stylesheet" href="/css/custom/text.css">
    <link rel="stylesheet" href="/css/custom/all.css">
</head>

<body id="body">
    <section class="pages-section">
        <div class="row">
            <div class="col-12 col-md-3 col-lg-3 col-xl-2 order-1 order-md-1">
                <div id="sidebar" class="sidebar" role="navigation">
                    <!-- sidebar -->
                    <%- include('sidebar') %>

                </div>
            </div>
            <div class="col-12 col-md-9 col-lg-9 col-xl-10 order-2 order-md-2 page-content" role="main">
                <div class="cust-container">
                    <div class="row">
                        <div class="col-12 col-md-6 mb-4">
                            <div class="post-card">
                                <!-- Card Header -->
                                <div class="card-header d-flex">
                                    <div >
                                        <img class="profile-photo" src="/images/pages/profile-photo.svg"
                                            alt="profile-photo">
                                    </div>
                                    <div class="p-3">
                                        <p class="profile-name-text">Siemens Industry</p>
                                    </div>
                                </div>
                                <!-- Image -->
                                <img src="/images/pages/feed.jpg" class="post-image" alt="Siemens">
                                <!-- Card Body -->
                                <div class="card-body">
                                    <p class="post-text">
                                        Get your free ticket for SPS 2024! Join us November 12–14 and unlock innovations,
                                        stage presentations, and guided tours with your free ticket.
                                    </p>
                                </div>
                                
    
                                <!-- Card Footer -->
                                <div class="card-footer d-flex justify-content-between align-items-center">
                                    <i class="fa-regular fa-heart" style="cursor: pointer; color: white;"></i>
                                    <i class="fa-regular fa-comment" style="cursor: pointer; color: white;"></i>
                                    <i class="fa-solid fa-share" style="cursor: pointer; color: white;"></i>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 mb-4">
                            <div class="post-card">
                                <!-- Card Header -->
                                <div class="card-header d-flex">
                                    <div>
                                        <img class="profile-photo" src="/images/pages/profile-photo.svg"
                                            alt="profile-photo">
                                    </div>
                                    <div class="p-3">
                                        <p class="profile-name-text">Siemens Industry</p>
                                    </div>
                                </div>
                                <!-- Image -->
                                <img src="/images/pages/feed.jpg" class="post-image" alt="Siemens">
                                <!-- Card Body -->
                                <div class="card-body">
                                    <p class="post-text">
                                        Get your free ticket for SPS 2024! Join us November 12–14 and unlock innovations,
                                        stage presentations, and guided tours with your free ticket.
                                    </p>
                                </div>
                                
    
                                <!-- Card Footer -->
                                <div class="card-footer d-flex justify-content-between align-items-center">
                                    <i class="fa-regular fa-heart" style="cursor: pointer; color: white;"></i>
                                    <i class="fa-regular fa-comment" style="cursor: pointer; color: white;"></i>
                                    <i class="fa-solid fa-share" style="cursor: pointer; color: white;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </section>

    <script src="./sidebar.js"></script>
    <script src="/js/jquery.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
    <script>
        $('#a1').addClass('sidebar-item-active')
    </script>
</body>

</html>